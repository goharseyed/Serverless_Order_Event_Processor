{
  "name": "order-validator-lambda",
  "version": "1.0.0",
  "description": "Node.js Lambda for validating order events and publishing to SNS",
  "main": "src/handler.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.800.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "@jest/globals": "^30.2.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
